#!/usr/bin/env php
<?php

$ROOT = __DIR__;

// Minimal autoloader
spl_autoload_register(function ($class) use ($ROOT) {
    $paths = [
        "$ROOT/src/$class.php",
        "$ROOT/Commands/$class.php",
        "$ROOT/vendor/$class.php",
    ];
    foreach ($paths as $path) {
        if (file_exists($path)) { require $path; return; }
    }
});

$command = $argv[1] ?? 'help';

switch ($command) {
    case 'init':
    case 'require':
        require __DIR__ . '/Commands/InitCommand.php';
        (new InitCommand())->run(array_slice($argv, 2));
        break;

    case 'install':
        require __DIR__ . '/Commands/InstallCommand.php';
        (new InstallCommand())->run();
        break;

    case 'verify':
        require __DIR__ . '/Commands/VerifyCommand.php';
        (new VerifyCommand())->run();
        break;

    case 'remove':
    case 'uninstall':
        require __DIR__ . '/Commands/RemoveCommand.php';
        (new RemoveCommand())->run(array_slice($argv, 2));
        break;

    case 'update':
    case 'upgrade':
        require __DIR__ . '/Commands/UpdateCommand.php';
        (new UpdateCommand())->run(array_slice($argv, 2));
        break;

    case 'list':
        $dirs = glob(__DIR__ . '/vendor/*', GLOB_ONLYDIR);
        if (!$dirs) { echo "No packages installed.\n"; break; }
        foreach ($dirs as $pkg) {
            $name = basename($pkg);
            $info = json_decode(@file_get_contents("$pkg/package.json"), true);
            $version = $info['version'] ?? '?';
            echo "  $name@$version\n";
        }
        break;

    case 'help':
        echo "pak-it - Universal PHP package manager\n";
        echo "Usage:\n";
        echo "  php pak-it init <package> [version]      Download and convert a package\n";
        echo "  php pak-it require <package> [version]   Alias for init\n";
        echo "  php pak-it update <package> [--all]      Re-download & re-convert a package\n";
        echo "  php pak-it remove <package> [--all]      Uninstall a package\n";
        echo "  php pak-it list                          Show installed packages\n";
        echo "  php pak-it install                       Batch install from pak-it.json\n";
        echo "  php pak-it <pkg> [args...]               Run a package's CLI (vendor/ or pkg-run.json)\n";
        echo "  php pak-it <npm|pip|brew|npx|...> [...]   Native package manager passthrough\n";
        echo "  php pak-it verify                        Syntax-check all converted files\n";
        echo "  php pak-it help                          Show this help\n";
        break;

    default:
        // Native package manager passthrough: php pak-it npm install -g ...
        $nativeRunners = ['npm', 'pip', 'pip3', 'brew', 'npx', 'cargo', 'go'];
        if (in_array($command, $nativeRunners, true)) {
            $cmd = implode(' ', array_map('escapeshellarg', array_merge([$command], array_slice($argv, 2))));
            $descriptors = [0 => STDIN, 1 => STDOUT, 2 => STDERR];
            $proc = proc_open($cmd, $descriptors, $pipes);
            if (!$proc) { echo "Error: Failed to launch command\n"; exit(1); }
            exit(proc_close($proc));
        }

        // Try to run as a package CLI (from vendor/ or pkg-run.json)
        require __DIR__ . '/Commands/RunCommand.php';
        (new RunCommand())->run($command, array_slice($argv, 2));
        break;
}
